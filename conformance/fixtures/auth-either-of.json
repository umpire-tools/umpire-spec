{
  "fixtureVersion": 1,
  "id": "auth-either-of",
  "description": "eitherOf() with named auth paths: submit is enabled when any branch's ANDed rules all pass. Covers single-branch pass, multi-branch pass, all-branches-fail, and a three-branch scenario.",
  "schema": {
    "version": 1,
    "conditions": {
      "ssoAvailable": {
        "type": "boolean",
        "description": "Whether SSO is configured for this domain"
      },
      "magicLinkEnabled": {
        "type": "boolean",
        "description": "Whether magic link auth is enabled for this tenant"
      }
    },
    "fields": {
      "email": {
        "isEmpty": "string"
      },
      "password": {
        "isEmpty": "string"
      },
      "ssoToken": {
        "isEmpty": "string"
      },
      "submit": {}
    },
    "rules": [
      {
        "type": "eitherOf",
        "group": "authPath",
        "branches": {
          "password": [
            {
              "type": "enabledWhen",
              "field": "submit",
              "when": {
                "op": "present",
                "field": "email"
              },
              "reason": "Enter your email"
            },
            {
              "type": "enabledWhen",
              "field": "submit",
              "when": {
                "op": "present",
                "field": "password"
              },
              "reason": "Enter your password"
            }
          ],
          "sso": [
            {
              "type": "enabledWhen",
              "field": "submit",
              "when": {
                "op": "cond",
                "condition": "ssoAvailable"
              },
              "reason": "SSO is not available for this account"
            },
            {
              "type": "enabledWhen",
              "field": "submit",
              "when": {
                "op": "present",
                "field": "email"
              },
              "reason": "Enter your email"
            }
          ],
          "magicLink": [
            {
              "type": "enabledWhen",
              "field": "submit",
              "when": {
                "op": "cond",
                "condition": "magicLinkEnabled"
              },
              "reason": "Magic link is not enabled for this tenant"
            },
            {
              "type": "enabledWhen",
              "field": "submit",
              "when": {
                "op": "present",
                "field": "email"
              },
              "reason": "Enter your email"
            }
          ]
        }
      }
    ]
  },
  "cases": [
    {
      "id": "password-branch-passes",
      "values": {
        "email": "scout@example.com",
        "password": "hunter2"
      },
      "conditions": {
        "ssoAvailable": false,
        "magicLinkEnabled": false
      },
      "expectedAvailability": {
        "email": {
          "enabled": true,
          "fair": true,
          "required": false,
          "reason": null,
          "reasons": [],
          "satisfied": true
        },
        "password": {
          "enabled": true,
          "fair": true,
          "required": false,
          "reason": null,
          "reasons": [],
          "satisfied": true
        },
        "ssoToken": {
          "enabled": true,
          "fair": true,
          "required": false,
          "reason": null,
          "reasons": [],
          "satisfied": false
        },
        "submit": {
          "enabled": true,
          "fair": true,
          "required": false,
          "reason": null,
          "reasons": [],
          "satisfied": false
        }
      }
    },
    {
      "id": "sso-branch-passes",
      "values": {
        "email": "scout@enterprise.com",
        "ssoToken": "tok_abc"
      },
      "conditions": {
        "ssoAvailable": true,
        "magicLinkEnabled": false
      },
      "expectedAvailability": {
        "email": {
          "enabled": true,
