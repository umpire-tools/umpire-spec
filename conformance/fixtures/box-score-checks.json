    "rules": [
      {
        "type": "check",
        "field": "scorerEmail",
        "op": "email"
      },
      {
        "type": "check",
        "field": "highlightUrl",
        "op": "url"
      },
      {
        "type": "check",
        "field": "jerseyNumber",
        "op": "matches",
        "pattern": "^[0-9]{1,2}$"
      },
      {
        "type": "check",
        "field": "benchBats",
        "op": "minLength",
        "value": 1
      },
      {
        "type": "check",
        "field": "walkupClips",
        "op": "maxLength",
        "value": 3
      },
      {
        "type": "check",
        "field": "pitchCount",
        "op": "min",
        "value": 1
      },
      {
        "type": "check",
        "field": "bullpenArms",
        "op": "max",
        "value": 8
      },
      {
        "type": "check",
        "field": "lineupSlot",
        "op": "range",
        "min": 1,
        "max": 9
      },
      {
        "type": "check",
        "field": "inning",
        "op": "integer"
      }
    ]
  },
