{
  "fixtureVersion": 1,
  "id": "box-score-checks",
  "description": "Named portable checks should behave the same way everywhere and use the same default reasons when no rule-level override is supplied.",
  "schema": {
    "version": 1,
    "fields": {
      "scorerEmail": {},
      "highlightUrl": {},
      "jerseyNumber": {},
      "benchBats": {},
      "walkupClips": {},
      "pitchCount": {},
      "bullpenArms": {},
      "lineupSlot": {},
      "inning": {}
