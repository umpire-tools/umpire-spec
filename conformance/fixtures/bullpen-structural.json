{
  "fixtureVersion": 1,
  "id": "bullpen-structural",
  "description": "Structural availability, conditions, oneOf prev resolution, anyOf, fairWhen, and excluded carry-forward.",
  "schema": {
    "version": 1,
    "conditions": {
      "isPlayoffs": {
        "type": "boolean",
        "description": "Whether the club is in postseason mode"
      },
      "availablePitchers": {
        "type": "string[]",
        "description": "Pitchers available for tonight's game"
      }
    },
    "fields": {
      "startingPitcher": {
        "required": true,
        "isEmpty": "string"
      },
      "bullpenPhone": {
        "isEmpty": "string"
      },
      "outfieldSignal": {
        "isEmpty": "string"
      },
      "closerReady": {},
      "inning": {
        "default": 1,
        "isEmpty": "number"
      },
      "pitcherCard": {
        "isEmpty": "object"
      },
      "benchBats": {
        "isEmpty": "array"
      },
      "stealCoverOn": {
        "isEmpty": "boolean"
      },
      "dugoutReady": {}
    },
    "rules": [
      {
        "type": "oneOf",
        "group": "bullpenCall",
        "branches": {
          "phone": ["bullpenPhone"],
          "signal": ["outfieldSignal"]
        }
      },
      {
        "type": "requires",
        "field": "bullpenPhone",
        "dependency": "startingPitcher"
      },
      {
        "type": "requires",
        "field": "dugoutReady",
        "dependency": "pitcherCard"
      },
      {
        "type": "requires",
        "field": "dugoutReady",
        "dependency": "benchBats"
      },
      {
        "type": "requires",
        "field": "dugoutReady",
        "dependency": "stealCoverOn"
      },
      {
        "type": "requires",
        "field": "dugoutReady",
        "dependency": "inning"
      },
      {
        "type": "anyOf",
        "rules": [
          {
            "type": "enabledWhen",
            "field": "closerReady",
            "when": {
              "op": "cond",
              "condition": "isPlayoffs"
            },
            "reason": "Playoff game keeps the closer hot"
          },
          {
            "type": "enabledWhen",
            "field": "closerReady",
            "when": {
              "op": "eq",
              "field": "inning",
              "value": 9
            },
            "reason": "Closer waits for the ninth"
          }
        ]
      },
      {
        "type": "fairWhen",
        "field": "startingPitcher",
        "when": {
          "op": "fieldInCond",
          "field": "startingPitcher",
          "condition": "availablePitchers"
        },
        "reason": "Starting pitcher is not available tonight"
      }
    ],
    "excluded": [
      {
        "type": "custom",
        "field": "dugoutReady",
        "description": "Home clubhouse still tracks some prep steps on a whiteboard",
        "key": "clubhouse:whiteboard:dugoutReady"
      }
    ]
  },
