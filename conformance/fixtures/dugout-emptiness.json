{
  "fixtureVersion": 1,
  "id": "dugout-emptiness",
  "description": "Portable isEmpty strategies should agree on what counts as present before a dependency can unlock a target field.",
  "schema": {
    "version": 1,
    "fields": {
      "scoutingNote": {
        "isEmpty": "string"
      },
      "benchBats": {
        "isEmpty": "array"
      },
      "pitcherCard": {
        "isEmpty": "object"
      },
      "inning": {
        "isEmpty": "number"
      },
      "shiftOn": {
        "isEmpty": "boolean"
      },
      "pregameChecklistReady": {}
    },
    "rules": [
