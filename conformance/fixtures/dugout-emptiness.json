        "pitcherCard": {},
        "inning": null,
        "shiftOn": null
      },
      "expectedAvailability": {
        "scoutingNote": {
          "enabled": true,
          "fair": true,
          "required": false,
          "reason": null,
          "reasons": [],
          "satisfied": false
        },
        "benchBats": {
          "enabled": true,
          "fair": true,
          "required": false,
          "reason": null,
          "reasons": [],
          "satisfied": false
        },
        "pitcherCard": {
          "enabled": true,
          "fair": true,
          "required": false,
          "reason": null,
          "reasons": [],
          "satisfied": false
        },
        "inning": {
          "enabled": true,
          "fair": true,
          "required": false,
          "reason": null,
          "reasons": [],
          "satisfied": false
        },
        "shiftOn": {
          "enabled": true,
          "fair": true,
          "required": false,
          "reason": null,
          "reasons": [],
          "satisfied": false
        },
        "pregameChecklistReady": {
          "enabled": false,
          "fair": true,
          "required": false,
          "reason": "requires scoutingNote",
